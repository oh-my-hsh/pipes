#!/usr/bin/env python3
"""
flux-render: Universal Markup & Format Converter for Flux Protocol Signals

Converts Flux Protocol (NDJSON) signal streams to various external formats
(JSON, Markdown, CSV, YAML) and vice versa. Acts as the "interchange"
layer between the Flux ecosystem and the outside world.

Usage:
    flux-eye /vault | python3 flux_render.py --to md
    flux-pulse | python3 flux_render.py --to json --pretty
    flux-eye /vault | python3 flux_render.py --to csv
    cat data.csv | python3 flux_render.py --from csv --to ndjson
"""

import sys
import json
import csv
import argparse
from datetime import datetime, timezone
from typing import List, Dict, Any, Optional

# ========================================
# Parsers (Input -> Signals)
# ========================================

def parse_ndjson(stream) -> List[Dict[str, Any]]:
    """Parse newline-delimited JSON stream into a list of signals."""
    signals = []
    for line in stream:
        line = line.strip()
        if not line:
            continue
        try:
            signals.append(json.loads(line))
        except json.JSONDecodeError as e:
            print(f"Warning: Invalid JSON line skipped: {e}", file=sys.stderr)
    return signals

def parse_json(stream) -> List[Dict[str, Any]]:
    """Parse standard JSON (object or array) into a list of signals."""
    content = stream.read()
    if not content.strip():
        return []
    try:
        data = json.loads(content)
        if isinstance(data, list):
            return data
        elif isinstance(data, dict):
            return [data]
        else:
            print("Warning: JSON input must be an object or array", file=sys.stderr)
            return []
    except json.JSONDecodeError as e:
        print(f"Error: Invalid JSON input: {e}", file=sys.stderr)
        return []

def parse_csv(stream) -> List[Dict[str, Any]]:
    """Parse CSV into a list of signals, treating headers as keys."""
    signals = []
    try:
        reader = csv.DictReader(stream)
        for row in reader:
            # Enforce minimal Flux Protocol structure if missing
            if "v" not in row:
                row["v"] = 1
            if "source" not in row:
                row["source"] = "csv-import"
            if "type" not in row:
                row["type"] = "row"
            signals.append(row)
    except csv.Error as e:
        print(f"Error: CSV parsing failed: {e}", file=sys.stderr)
    return signals


# ========================================
# Serializers (Signals -> Output)
# ========================================

def serialize_ndjson(signals: List[Dict[str, Any]], **kwargs) -> None:
    """Output signals as newline-delimited JSON."""
    for signal in signals:
        print(json.dumps(signal, ensure_ascii=False))

def serialize_json(signals: List[Dict[str, Any]], pretty: bool = False, **kwargs) -> None:
    """Output signals as a JSON array."""
    indent = 2 if pretty else None
    print(json.dumps(signals, ensure_ascii=False, indent=indent))

def serialize_csv(signals: List[Dict[str, Any]], **kwargs) -> None:
    """Output signals as CSV."""
    if not signals:
        return
    
    # Collect all unique keys for header
    keys = set()
    for signal in signals:
        keys.update(signal.keys())
    
    # Sort keys for consistency (put common Flux fields first)
    priority_keys = ["v", "source", "type", "timestamp", "name", "path", "score"]
    sorted_keys = [k for k in priority_keys if k in keys]
    sorted_keys.extend(sorted(list(keys - set(priority_keys))))
    
    writer = csv.DictWriter(sys.stdout, fieldnames=sorted_keys)
    writer.writeheader()
    writer.writerows(signals)

def _format_markdown_table(signals: List[Dict[str, Any]], columns: List[str]) -> str:
    """Helper to render a Markdown table."""
    if not signals:
        return ""
    
    # Header
    header = "| " + " | ".join([c.capitalize() for c in columns]) + " |"
    separator = "| " + " | ".join(["---"] * len(columns)) + " |"
    rows = [header, separator]
    
    for s in signals:
        row = "| " + " | ".join([str(s.get(c, "")) for c in columns]) + " |"
        rows.append(row)
    
    return "\n".join(rows)

def serialize_md(signals: List[Dict[str, Any]], timestamp: Optional[str] = None, **kwargs) -> None:
    """Output signals as a formulated Markdown report (SITREP)."""
    
    ts = timestamp or datetime.now(timezone.utc).strftime("%Y-%m-%d %H:%M:%S UTC")
    print(f"# Flux SITREP - {ts}\n")
    
    if not signals:
        print("*No signals received.*")
        return

    # Group by source
    grouped = {}
    for s in signals:
        source = s.get("source", "unknown")
        if source not in grouped:
            grouped[source] = []
        grouped[source].append(s)
    
    # Render each group
    for source, group_signals in grouped.items():
        print(f"### 📡 Source: `{source}`\n")
        
        # Dispatch based on source type (heuristic)
        if source == "flux-pulse":
            # Bullet list for system stats
            for s in group_signals:
                alert_icon = "🟢" if s.get("alert") == "normal" else "🔴" if s.get("alert") == "critical" else "🟡"
                print(f"- {alert_icon} **{s.get('timestamp', '')}**")
                print(f"  - CPU: `{s.get('cpu_percent')}%` / MEM: `{s.get('memory_percent')}%`")
                print(f"  - Disk: `{s.get('disk_percent')}%`")
                if s.get("load_avg"):
                    print(f"  - Load: `{s.get('load_avg')}`")
            print("")
            
        elif source == "flux-eye":
            # Pre-process signals to ensure 'name' exists
            for s in group_signals:
                if not s.get("name") and s.get("path"):
                    s["name"] = s["path"].split("/")[-1]
            
            # File table
            cols = ["name", "extension", "size", "modified"]
            print(_format_markdown_table(group_signals, cols))
            print("\n> Total files: {}\n".format(len(group_signals)))
            
        elif source == "flux-grep":
            # Search results
            for s in group_signals:
                filepath = s.get("path", "unknown")
                line_no = s.get("line_number", "?")
                content = s.get("line_content", "").strip()
                print(f"- **{filepath}:{line_no}**")
                print(f"> {content}\n")
                
        elif source in ["trending-github", "fetch-rss"]:
            # News / Links
            for s in group_signals:
                title = s.get("title", "No Title")
                link = s.get("link", s.get("url", "#"))
                desc = s.get("description", s.get("ai_summary", ""))
                print(f"- [{title}]({link})")
                if desc:
                    print(f"  > {desc}")
            print("")
            
        elif source == "flux-priority":
            # Priority Table
            # Extract path from payload if possible
            for s in group_signals:
                payload = s.get("payload", {})
                s["path"] = payload.get("path", s.get("path", "unknown"))
                
                # Format score
                s["score_fmt"] = f"{s.get('score', 0.0):.2f}"
                
                # Top reason summary
                reasons = s.get("reasons", [])
                if reasons:
                    # Sort reasons by value contribution (value * weight)
                    top_reason = max(reasons, key=lambda r: r.get("value", 0) * r.get("weight", 0))
                    s["top_reason"] = f"{top_reason.get('factor')} ({top_reason.get('detail')})"
                else:
                    s["top_reason"] = "-"

            cols = ["rank", "score_fmt", "path", "top_reason"]
            print(_format_markdown_table(group_signals, cols))
            print("")
            
        else:
            # Default: Generic JSON dump (truncated if too many)
            max_items = 5
            print(f"```json")
            print(json.dumps(group_signals[:max_items], indent=2, ensure_ascii=False))
            print(f"```")
            if len(group_signals) > max_items:
                print(f"*...and {len(group_signals) - max_items} more items.*")
            print("")
            
    print("---\n*Generated by flux-render*")


# ========================================
# Main Conversion Logic
# ========================================

def process_stream(input_format: str, output_format: str, wrap: bool, pretty: bool):
    """Orchestrate the conversion process."""
    
    # 1. Parse Input -> Signals
    signals = []
    if input_format == "ndjson":
        signals = parse_ndjson(sys.stdin)
    elif input_format == "json":
        signals = parse_json(sys.stdin)
    elif input_format == "csv":
        signals = parse_csv(sys.stdin)
    else:
        print(f"Error: Unsupported input format '{input_format}'", file=sys.stderr)
        sys.exit(1)

    # 2. Serialize Signals -> Output
    if wrap:
        # Wrap output in a Flux Protocol v1 envelope
        # NOTE: This creates a NEW signal containing the rendered output as a body
        # This implementation slightly differs from simple piping instructions
        pass # Not implementing complex wrap logic yet, sticking to simple wrapper
        
    
    if output_format == "ndjson":
        serialize_ndjson(signals)
    elif output_format == "json":
        serialize_json(signals, pretty=pretty)
    elif output_format == "csv":
        serialize_csv(signals)
    elif output_format == "md":
        serialize_md(signals)
    else:
        print(f"Error: Unsupported output format '{output_format}'", file=sys.stderr)
        sys.exit(1)


def main():
    parser = argparse.ArgumentParser(
        description="flux-render: Universal Markup & Format Converter for Flux Protocol Signals",
        formatter_class=argparse.RawDescriptionHelpFormatter
    )
    
    parser.add_argument("--from", dest="from_fmt", default="ndjson",
                        choices=["ndjson", "json", "csv"],
                        help="Input format (default: ndjson)")
    
    parser.add_argument("--to", dest="to_fmt", default="md",
                        choices=["ndjson", "json", "csv", "md"],
                        help="Output format (default: md)")
    
    parser.add_argument("--wrap", action="store_true",
                        help="Wrap output in Flux Protocol envelope (Not fully implemented in Phase 1)")
    
    parser.add_argument("--pretty", action="store_true",
                        help="Pretty print JSON output")
    
    args = parser.parse_args()
    
    process_stream(args.from_fmt, args.to_fmt, args.wrap, args.pretty)


if __name__ == "__main__":
    main()
