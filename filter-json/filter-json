#!/usr/bin/env python3
"""filter-json: Filter NDJSON streams by keyword across all fields."""
import json
import sys
import argparse

def main():
    parser = argparse.ArgumentParser(description='Filter NDJSON stream by keyword')
    parser.add_argument('--keyword', type=str, default=None, help='Keyword to filter (case-insensitive)')
    parser.add_argument('--field', type=str, default=None, help='Specific field to search (default: all fields)')
    args = parser.parse_args()

    for line in sys.stdin:
        try:
            line = line.strip()
            if not line:
                continue

            item = json.loads(line)

            # キーワードが指定されていない場合はすべて通す
            if not args.keyword:
                print(json.dumps(item, ensure_ascii=False), flush=True)
                continue

            keyword = args.keyword.lower()

            # 特定フィールド指定時
            if args.field:
                value = str(item.get(args.field, "")).lower()
                if keyword in value:
                    print(json.dumps(item, ensure_ascii=False), flush=True)
                continue

            # 全フィールドを検索対象にする
            target_text = " ".join(str(v) for v in item.values()).lower()

            if keyword in target_text:
                try:
                    print(json.dumps(item, ensure_ascii=False), flush=True)
                except BrokenPipeError:
                    sys.exit(0)

        except json.JSONDecodeError:
            continue
        except BrokenPipeError:
            sys.exit(0)
        except Exception as e:
            print(f"Error: {e}", file=sys.stderr)
            continue

if __name__ == "__main__":
    main()
