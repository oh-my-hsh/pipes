#!/usr/bin/env python3
import json
import sys

def main():
    print("🚀 Starting RSS Monitoring Pipeline Output...\n")
    print(f"{'Source':<20} | {'Title':<50} | {'AI Summary'}")
    print("-" * 100)

    count = 0
    for line in sys.stdin:
        try:
            item = json.loads(line)
            
            source = item.get("source", "")[:18]
            title = item.get("title", "")[:48]
            ai_summary = item.get("ai_summary", "")
            
            # 表形式っぽく整形して出力
            print(f"{source:<20} | {title:<50} | {ai_summary}")
            count += 1
            
        except json.JSONDecodeError:
            pass
            
    print(f"\n✅ Pipeline finished. Processed {count} items.")

if __name__ == "__main__":
    main()
