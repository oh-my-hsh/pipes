#!/usr/bin/env python3
"""json-to-table: Render NDJSON streams as formatted ASCII tables."""
import json
import sys

def main():
    rows = []
    all_keys = []
    seen_keys = set()

    for line in sys.stdin:
        try:
            line = line.strip()
            if not line:
                continue
            item = json.loads(line)
            rows.append(item)
            for k in item.keys():
                if k not in seen_keys:
                    seen_keys.add(k)
                    all_keys.append(k)
        except json.JSONDecodeError:
            continue
        except BrokenPipeError:
            sys.exit(0)

    if not rows:
        print("(no data)")
        return

    # カラム幅を計算
    col_widths = {}
    for k in all_keys:
        max_val = max(len(str(row.get(k, ""))) for row in rows)
        col_widths[k] = max(len(k), min(max_val, 50))

    # ヘッダー
    header = " | ".join(f"{k:{col_widths[k]}s}" for k in all_keys)
    sep = "-+-".join("-" * col_widths[k] for k in all_keys)
    print(header)
    print(sep)

    # 行
    for row in rows:
        vals = []
        for k in all_keys:
            v = str(row.get(k, ""))
            if len(v) > 50:
                v = v[:47] + "..."
            vals.append(f"{v:{col_widths[k]}s}")
        try:
            print(" | ".join(vals))
        except BrokenPipeError:
            sys.exit(0)

    print(f"\n({len(rows)} rows)")

if __name__ == "__main__":
    main()
